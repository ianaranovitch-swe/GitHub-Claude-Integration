# Скопируй этот файл как .env и вставь свои ключи:
#   copy .env.example .env

# GitHub Personal Access Token (classic)
# Права: repo (для приватных репозиториев)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (Claude) — serverns nyckel, användare behöver inte skicka den
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Telegram Bot Token (från @BotFather) — för telegram_bot.py
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Какие репозитории обрабатывать:
#   bots  = только Telegram-боты (по умолчанию)
#   all   = все репозитории
REPO_FILTER=bots

# Настройки лендинга (необязательно)
SITE_TITLE=Telegram-tjänster — använd mina botar
OUTPUT_HTML=index.html
CONTACT_EMAIL=din@email.se
MIN_PRICE_SEK=29
MAX_PRICE_SEK=499
CLAUDE_MODEL=claude-sonnet-4-6
