# Скопируй этот файл как .env и вставь свои ключи:
#   copy .env.example .env

# GitHub Personal Access Token (classic)
# Права: repo (для приватных репозиториев)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Какие репозитории обрабатывать:
#   bots  = только Telegram-боты (по умолчанию)
#   all   = все репозитории
REPO_FILTER=bots

# Настройки HTML-лендинга (необязательно)
SITE_TITLE=Telegram-botar till salu
OUTPUT_HTML=index.html
CONTACT_EMAIL=din@email.se
